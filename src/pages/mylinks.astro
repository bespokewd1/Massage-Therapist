---
import SecondaryLayout from "src/layouts/SecondaryLayout.astro";
import Logo from '@assets/images/logo/updated-logo.png';
import { Image } from 'astro:assets';

// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Landing (for rendering)
import {getOptimizedImage} from "@js/utils"
import landingImage from "@assets/images/landing.jpg" // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
const optimizedImage = await getOptimizedImage(landingImage)
---

<SecondaryLayout
  title="Hot Stone Massage Edmonton - Professional Massage Therapy"
  preloadedImage = {optimizedImage}
>


  <!-- ============================================ -->
  <!--                 Bio Link                     -->
  <!-- ============================================ -->
  <div id="bio-link">
    <Image
        src={Logo}
        alt="Logo"
        class="logo"            
      />
    <h1>Hot Stone Massage – Edmonton</h1>
    <p><em>Relax. Rejuvenate. Revive.</em></p>
    <!-- <p>Professional massage therapy for relaxation, pain relief, and wellness in Edmonton.</p> -->
    <!-- <div class="phone">📞 587-938-0458</div> -->
  
    <a href="tel:5879380458" class="link-btn">📞 Call for Mobile Massage</a>
    <a href="https://www.massagebook.com/therapists/StoneMassage?src=external" class="link-btn" target="_blank">🗓️ Book Online for In-Clinic Massage</a>
    <a href="https://stonemassage.ca" class="link-btn">🌐 Visit Our Official Website</a>
    <a href="https://www.facebook.com/profile.php?id=61576565295541" class="link-btn" target="_blank">👍 Follow Us on Facebook</a>
    <a href="https://www.instagram.com/stonemassage.yeg/" class="link-btn" target="_blank">📸 Follow Us on Instagram</a>
    <a href="https://maps.app.goo.gl/qviXiGpS6h1b8kYp8" class="link-btn" target="_blank">📍 Check Our Address on Google Maps</a>
  
    <footer>
      © 2025 Bespoke Web Design. All rights reserved.
    </footer>
  
  </div>

</SecondaryLayout>

<style lang="less">
  /* PAGE-SPECIFIC STYLES FOR THE ABOUT PAGE */

  body{
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #ffe6ec;
    color: #333;
    text-align: center;
    padding: 30px 20px;
  }
  #cs-navigation{
    display: none;
  }
  /* Mobile - 360px */  
  @media only screen and (min-width: 0em) {
    #bio-link{
    .logo {
      width: 96px;
      height: 96px;
      margin: 0 auto 1.2rem;
    //   border-radius: 50%;
      object-fit: cover;
    //   box-shadow: 0 6px 16px rgba(0,0,0,0.1);
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 500;
      color: #d63384;
      margin-bottom: 5px;
    }

    p {
      font-size: 1rem;
      margin: 5px 0 2px;
    }

    .phone {
      font-size: 1.1rem;
      font-weight: bold;
      color: #333;
      margin-bottom: 30px;
    }

    .link-btn {
      display: block;
      background: #ff69b4;
      color: white;
      padding: 14px 15px;
      margin: 10px auto;
      border: none;
      border-radius: 30px;
      text-decoration: none;
      max-width: 320px;
      font-size: 1rem;
      transition: background 0.3s ease;
    }

    .link-btn:hover {
      background: #e055a1;
    }

    footer {
      margin-top: 40px;
      font-size: 0.8rem;
      color: #666;
    }
    }
  }
 
  @media only screen and (min-width: 48em) {
    #bio-link{
        .link-btn{
            padding: 14px 20px;
        }
    }
  }

  /* Dark Mode */
  @media only screen and (min-width: 0em) {
    body.dark-mode {

    }
  }
</style>
