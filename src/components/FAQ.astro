---
const faqs = [
  {
    question: 'What types of massage do you offer?',
    answer:
      'We offer a variety of massages, including Swedish, deep tissue, hot stone, prenatal, and therapeutic massage. Our therapists will help you choose the best option for your needs.',
  },
  {
    question: 'How do I book an appointment?',
    answer:
      'You can book a mobile massage by calling us — we’ll come to your home. For a clinic massage, simply click “Book Online” to schedule your visit at our location.',
  },
  {
    question: 'What should I expect during my first massage session?',
    answer:
      'Your therapist will discuss your needs and preferences before beginning the session. You’ll be given privacy to get comfortable, and the therapist will ensure you feel relaxed throughout the treatment.',
  },
  {
    question: 'What payment methods do you accept?',
    answer:
      'We accept credit/debit cards, cash, and online payments. Gift cards and package deals are also available for purchase.',
  },
  {
    question: 'What should I wear for my massage?',
    answer:
      'You can undress to your comfort level. Our therapists use professional draping techniques to ensure your privacy and comfort at all times.',
  },
  {
    question: 'Can I request a specific therapist?',
    answer:
      'Yes! If you have a preferred therapist, please mention it when booking your appointment, and we’ll do our best to accommodate your request.',
  },
];
---

<section
  id="faq-1741"
  class="relative px-4 py-[clamp(3.75rem,7.82vw,6.25rem)]"
>
  <div
    class="mx-auto my-8 flex max-w-[36.5rem] flex-col items-center gap-[clamp(3rem,6vw,4rem)] lg:max-w-[80rem] lg:flex-row lg:items-stretch lg:justify-between"
  >
    <div
      class="flex w-full flex-col items-center text-center lg:w-[40%] lg:flex-none lg:items-start lg:text-left"
    >
      <span
        class="mb-2 block text-[clamp(0.8125rem,1.6vw,1rem)] font-bold uppercase tracking-[0.1em] text-[var(--secondary)]"
      >
        Frequently Asked Questions
      </span>

      <h2
        class="max-w-[15ch] text-[clamp(1.9375rem,3.9vw,3.0625rem)] font-medium leading-[1.2] text-[var(--headerColor)]"
      >
        Everything You Need to Know About Our Massage Services
      </h2>
    </div>

    <ul class="flex w-full flex-col gap-3">
      {
        faqs.map((faq, index) => (
          <li class="list-none">
            <details class="group overflow-hidden" open={index === 0}>
              <summary
                class="relative block cursor-pointer list-none border border-[#e8e8e8] bg-transparent py-4 pl-12 pr-4 text-left text-[clamp(1rem,2.5vw,1.25rem)] font-bold leading-[1.2] text-[var(--headerColor)] transition-colors duration-300 marker:content-[''] [&::-webkit-details-marker]:hidden group-open:bg-[var(--secondary)] group-open:text-[var(--bodyTextColorWhite)]"
              >
                <svg
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 transition-transform duration-300 group-open:rotate-180"
                  aria-hidden="true"
                >
                  <path d="M5 7.5 10 12.5 15 7.5"></path>
                </svg>

                {faq.question}
              </summary>

              <div
                class="grid grid-rows-[0fr] transition-all duration-300 group-open:grid-rows-[1fr]"
              >
                <p
                  class="overflow-hidden border border-t-0 border-[#e8e8e8] px-4 py-0 text-[clamp(0.875rem,1.5vw,1rem)] leading-[1.5] text-[var(--bodyTextColor)] opacity-0 transition-all duration-300 group-open:px-6 group-open:py-4 group-open:opacity-100"
                >
                  {faq.answer}
                </p>
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>