---
import { Picture } from 'astro:assets';
import ctaBg from '@assets/images/CTA-Background-Image.jpg';
---

<section
  id="cta"
  class="relative overflow-hidden py-[3.125rem] lg:py-[10.5rem] xl:mt-[6.25rem]"
>
  <div class="relative z-10 mx-auto w-[92%] text-center xl:w-[90.0625%]">
    <h2
      class="mb-9 text-[min(9vw,4rem)] leading-[1.208] text-[var(--bodyTextColorWhite)]"
    >
      Relax. Rejuvenate. Restore.
    </h2>

    <p
      class="mx-auto mb-9 w-[96%] max-w-[37.375rem] text-[var(--bodyTextColorWhite)]"
    >
      Your Wellness Starts Here – Experience the Benefits of Massage!
    </p>

    <a
      href="/booking"
      class="inline-flex h-[3.125rem] items-center justify-center rounded-full bg-[var(--primary)] px-[1.875rem] text-base font-bold uppercase text-[var(--bodyTextColorWhite)] transition-colors duration-300 hover:bg-[#ff66ad]"
    >
      Book Online
    </a>
  </div>

  <Picture
    src={ctaBg}
    alt="stone arrangement with rolled towel"
    formats={['avif', 'webp']}
    loading="lazy"
    decoding="async"
    pictureAttributes={{
      class:
        'absolute inset-0 -z-10 h-full w-full xl:left-1/2 xl:w-[90.0625%] xl:-translate-x-1/2',
    }}
    class="h-full w-full object-cover"
  />
</section>